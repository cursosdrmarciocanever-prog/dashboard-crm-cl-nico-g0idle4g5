# Build do front (Vite) -> servido por nginx, que tambem faz proxy do PocketBase.
# As VITE_* sao "baked" no build (Vite injeta em tempo de compilacao).

FROM node:22-alpine AS build
WORKDIR /app
COPY . .
ARG VITE_POCKETBASE_URL
ARG VITE_CLINIC_WHATSAPP
ENV VITE_POCKETBASE_URL=$VITE_POCKETBASE_URL
ENV VITE_CLINIC_WHATSAPP=$VITE_CLINIC_WHATSAPP
RUN npm install && npm run build

FROM nginx:alpine
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
