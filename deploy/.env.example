# Copie para deploy/.env na VPS e ajuste. NAO commitar o .env real.

# Versao do PocketBase — DEVE bater com a do goskip (veja no rodape de /_/).
PB_VERSION=0.36.9
# Arquitetura do binario. VPS x86_64 = linux_amd64 (padrao). ARM = linux_arm64.
PB_ARCH=linux_amd64

# Dominio publico do CRM (front + API na mesma origem).
CRM_HOST=crm.clinicacanever.com.br
CRM_URL=https://crm.clinicacanever.com.br

# Nome do certresolver do SEU Traefik (copie do compose do app-financeiro).
CERT_RESOLVER=letsencrypt

# WhatsApp fallback (o valor oficial fica na colecao `settings`, editavel no app).
CLINIC_WHATSAPP=5544999999999
